<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Collection_Management.MainPage"
             Title="Zarządzanie Kolekcjami"
             BackgroundColor="#F5F7FC">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- Header -->
        <Grid Grid.Row="0" 
              BackgroundColor="#371CFC"
              Padding="20,15,20,15"
              RowDefinitions="Auto,Auto">
            <Label Text="Moje Kolekcje" 
                   FontSize="32" 
                   FontAttributes="Bold"
                   TextColor="White"
                   Margin="0,10,0,10"/>
            <Label Grid.Row="1"
                   Text="Proszę nie używać |"
                   FontSize="12"
                   TextColor="#FFD700"
                   FontAttributes="Bold"/>
        </Grid>

        <!-- Collections List -->
        <CollectionView Grid.Row="1" 
                        x:Name="CollectionsCollectionView"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding CollectionSelectedCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={x:Reference CollectionsCollectionView}}"
                        Margin="12,12,12,12">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#6180FF" 
                           Padding="16" 
                           Margin="0,0"
                           HasShadow="True"
                           BackgroundColor="White"
                           CornerRadius="12">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="15">
                            <StackLayout Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Spacing="8">
                                <Label Text="{Binding Name}" 
                                       FontAttributes="Bold"
                                       FontSize="20"
                                       TextColor="#1C48FC"/>
                                <Label Text="{Binding Type, StringFormat='Typ: {0}'}" 
                                       FontSize="14"
                                       TextColor="#6180FF"/>
                            </StackLayout>
                            <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                   Text="{Binding Items.Count, StringFormat='{0}'}" 
                                   FontSize="40"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"
                                   TextColor="#9034FF"
                                   WidthRequest="60"/>
                            <Label Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                   Text="szt." 
                                   FontSize="12"
                                   TextColor="#6180FF"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   Margin="20,0,0,0"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" Padding="12" ColumnSpacing="10" RowSpacing="10" BackgroundColor="White">
            <Button Grid.Row="0" Grid.Column="0"
                    Text="Nowa" 
                    FontAttributes="Bold"
                    FontSize="14"
                    BackgroundColor="#371CFC"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="8,12"
                    Clicked="OnAddCollectionClicked"/>
            <Button Grid.Row="0" Grid.Column="1"
                    Text="Edytuj" 
                    FontAttributes="Bold"
                    FontSize="14"
                    BackgroundColor="#1CD6FC"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="8,12"
                    Clicked="OnEditCollectionClicked"/>
            <Button Grid.Row="0" Grid.Column="2"
                    Text="Usuń" 
                    FontAttributes="Bold"
                    FontSize="14"
                    BackgroundColor="#9034FF"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="8,12"
                    Clicked="OnDeleteCollectionClicked"/>
            <Button Grid.Row="0" Grid.Column="3"
                    Text="Podsumowanie" 
                    FontAttributes="Bold"
                    FontSize="13"
                    BackgroundColor="#42A3FF"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="8,12"
                    Clicked="OnSummaryClicked"/>
            <Button Grid.Row="1" Grid.Column="0"
                    Text="Załaduj" 
                    FontAttributes="Bold"
                    FontSize="14"
                    BackgroundColor="#6180FF"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="8,12"
                    Clicked="OnLoadFileClicked"/>
            <Button Grid.Row="1" Grid.Column="1"
                    Text="Zapisz" 
                    FontAttributes="Bold"
                    FontSize="14"
                    BackgroundColor="#1C48FC"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="8,12"
                    Clicked="OnFileSaveClicked"/>
            <Button Grid.Row="1" Grid.Column="2"
                    Text="Eksportuj" 
                    FontAttributes="Bold"
                    FontSize="14"
                    BackgroundColor="#42A3FF"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="8,12"
                    Clicked="OnExportCollectionClicked"/>
            <Button Grid.Row="1" Grid.Column="3"
                    Text="Importuj" 
                    FontAttributes="Bold"
                    FontSize="14"
                    BackgroundColor="#371CFC"
                    TextColor="White"
                    CornerRadius="10"
                    Padding="8,12"
                    Clicked="OnImportCollectionClicked"/>
        </Grid>
    </Grid>

</ContentPage>
