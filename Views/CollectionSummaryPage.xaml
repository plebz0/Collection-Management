<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Collection_Management.CollectionSummaryPage"
             Title="Podsumowanie Kolekcji">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="20" BackgroundColor="#F9F9F9">

        <!-- Header -->
        <StackLayout Grid.Row="0" Spacing="10" Padding="15" BackgroundColor="#371CFC">
            <Label x:Name="CollectionNameLabel" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="#FFFFFF"/>
            <Label x:Name="CollectionTypeLabel" 
                   FontSize="14" 
                   TextColor="#1CD6FC"/>
        </StackLayout>

        <!-- Statistics Cards -->
        <ScrollView Grid.Row="1">
            <StackLayout Spacing="15" Padding="0">
                
                <!-- Total Items Card -->
                <Frame CornerRadius="10" 
                       Padding="20" 
                       HasShadow="True"
                       BorderColor="#371CFC"
                       BackgroundColor="#F3E5F5">
                    <StackLayout Spacing="10">
                        <Label Text="Łączna liczba przedmiotów" 
                               FontSize="14" 
                               TextColor="#371CFC"
                               FontAttributes="Bold"/>
                        <Label x:Name="TotalItemsLabel" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#371CFC"/>
                    </StackLayout>
                </Frame>

                <!-- Possess Card -->
                <Frame CornerRadius="10" 
                       Padding="20" 
                       HasShadow="True"
                       BorderColor="#42A3FF"
                       BackgroundColor="#E3F2FD">
                    <StackLayout Spacing="10">
                        <Label Text="W posiadaniu" 
                               FontSize="14" 
                               TextColor="#1C48FC"
                               FontAttributes="Bold"/>
                        <Label x:Name="PossessLabel" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#1C48FC"/>
                        <Label x:Name="PossessPercentageLabel" 
                               FontSize="12" 
                               TextColor="#42A3FF"/>
                    </StackLayout>
                </Frame>

                <!-- WantToSell Card -->
                <Frame CornerRadius="10" 
                       Padding="20" 
                       HasShadow="True"
                       BorderColor="#9034FF"
                       BackgroundColor="#F3E5F5">
                    <StackLayout Spacing="10">
                        <Label Text="Chce Sprzedać" 
                               FontSize="14" 
                               TextColor="#6180FF"
                               FontAttributes="Bold"/>
                        <Label x:Name="WantToSellLabel" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#6180FF"/>
                        <Label x:Name="WantToSellPercentageLabel" 
                               FontSize="12" 
                               TextColor="#9034FF"/>
                    </StackLayout>
                </Frame>

                <!-- Sold Card -->
                <Frame CornerRadius="10" 
                       Padding="20" 
                       HasShadow="True"
                       BorderColor="#1CD6FC"
                       BackgroundColor="#E0F2F1">
                    <StackLayout Spacing="10">
                        <Label Text="Sprzedane" 
                               FontSize="14" 
                               TextColor="#00695C"
                               FontAttributes="Bold"/>
                        <Label x:Name="SoldLabel" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#00695C"/>
                        <Label x:Name="SoldPercentageLabel" 
                               FontSize="12" 
                               TextColor="#1CD6FC"/>
                    </StackLayout>
                </Frame>

            </StackLayout>
        </ScrollView>

        <!-- Back Button -->
        <Button Grid.Row="2"
                Text="Wróć"
                FontAttributes="Bold"
                BackgroundColor="#1C48FC"
                TextColor="#FFFFFF"
                Clicked="OnBackClicked"/>

    </Grid>

</ContentPage>
