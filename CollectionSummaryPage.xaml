<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Collection_Management.CollectionSummaryPage"
             Title="Podsumowanie Kolekcji">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="20">
        
        <!-- Header -->
        <StackLayout Grid.Row="0" Spacing="10">
            <Label x:Name="CollectionNameLabel" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="#333"/>
            <Label x:Name="CollectionTypeLabel" 
                   FontSize="14" 
                   TextColor="Gray"/>
        </StackLayout>

        <!-- Statistics Cards -->
        <ScrollView Grid.Row="1">
            <StackLayout Spacing="15" Padding="0">
                
                <!-- Total Items Card -->
                <Frame CornerRadius="10" 
                       Padding="20" 
                       HasShadow="True"
                       BorderColor="#E0E0E0"
                       BackgroundColor="#F9F9F9">
                    <StackLayout Spacing="10">
                        <Label Text="Łączna liczba przedmiotów" 
                               FontSize="14" 
                               TextColor="Gray"
                               FontAttributes="Bold"/>
                        <Label x:Name="TotalItemsLabel" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#333"/>
                    </StackLayout>
                </Frame>

                <!-- Possess Card -->
                <Frame CornerRadius="10" 
                       Padding="20" 
                       HasShadow="True"
                       BorderColor="#4CAF50"
                       BackgroundColor="#E8F5E9">
                    <StackLayout Spacing="10">
                        <Label Text="Posiadane przedmioty" 
                               FontSize="14" 
                               TextColor="#2E7D32"
                               FontAttributes="Bold"/>
                        <Label x:Name="PossessLabel" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#2E7D32"/>
                        <Label x:Name="PossessPercentageLabel" 
                               FontSize="12" 
                               TextColor="#558B2F"/>
                    </StackLayout>
                </Frame>

                <!-- WantToSell Card -->
                <Frame CornerRadius="10" 
                       Padding="20" 
                       HasShadow="True"
                       BorderColor="#FF9800"
                       BackgroundColor="#FFF3E0">
                    <StackLayout Spacing="10">
                        <Label Text="Przedmioty do sprzedania" 
                               FontSize="14" 
                               TextColor="#E65100"
                               FontAttributes="Bold"/>
                        <Label x:Name="WantToSellLabel" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#E65100"/>
                        <Label x:Name="WantToSellPercentageLabel" 
                               FontSize="12" 
                               TextColor="#BF360C"/>
                    </StackLayout>
                </Frame>

                <!-- Sold Card -->
                <Frame CornerRadius="10" 
                       Padding="20" 
                       HasShadow="True"
                       BorderColor="#9C27B0"
                       BackgroundColor="#F3E5F5">
                    <StackLayout Spacing="10">
                        <Label Text="Sprzedane przedmioty" 
                               FontSize="14" 
                               TextColor="#6A1B9A"
                               FontAttributes="Bold"/>
                        <Label x:Name="SoldLabel" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="#6A1B9A"/>
                        <Label x:Name="SoldPercentageLabel" 
                               FontSize="12" 
                               TextColor="#8E24AA"/>
                    </StackLayout>
                </Frame>

            </StackLayout>
        </ScrollView>

        <!-- Back Button -->
        <Button Grid.Row="2"
                Text="Wróć"
                FontAttributes="Bold"
                Clicked="OnBackClicked"/>

    </Grid>

</ContentPage>
